# FlowSight Configuration

# URL of the PM Dashboard (Agent connects to this)
# Local: http://localhost:8080
# Remote: https://your-ngrok-url.app or http://tailscale-ip:8080
VITE_PM_URL="http://localhost:8080"

# API Key for authentication (Get this from PM Dashboard -> Settings)
VITE_API_KEY=""

# Supabase Configuration (for Realtime Sync)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLIC_KEY="your-anon-key"

# OAuth Providers
# Jira/Atlassian - https://developer.atlassian.com/console/myapps/
VITE_JIRA_CLIENT_ID="your_atlassian_client_id"
VITE_JIRA_CLIENT_SECRET="your_atlassian_client_secret"

# Google OAuth - NOW HANDLED BY SUPABASE (no keys needed here)
# Configure in Supabase Dashboard -> Authentication -> Providers -> Google
# VITE_GOOGLE_CLIENT_ID="optional_if_using_direct_oauth"
# VITE_GOOGLE_CLIENT_SECRET="optional_if_using_direct_oauth"

# Linear - https://linear.app/settings/api
VITE_LINEAR_CLIENT_ID="your_linear_client_id"
VITE_LINEAR_CLIENT_SECRET="your_linear_client_secret"
