# FlowSight Configuration — copiar a .env.local y rellenar.
#
# NEXT_PUBLIC_* / VITE_*  → pueden acabar en el bundle del front (públicas por diseño).
# TAURI_* → solo las lee Rust; usa TAURI_* para secretos OAuth (no VITE_*).

# Supabase (cloud features: sync, AI insights, integrations)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase Edge Function secrets (set in Dashboard → Edge Functions → Secrets)
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_MODEL="xiaomi/mimo-v2.5-pro"
# SUPABASE_ACCESS_TOKEN="your-supabase-cli-token"
# SUPABASE_DB_PASSWORD="your-db-password"
# SUPABASE_SERVICE_ROLE_KEY="service-role-key-for-migrations-only"

# Jira/Atlassian — https://developer.atlassian.com/console/myapps/
# ID puede ser público; el secret NO debe usar prefijo VITE_.
TAURI_JIRA_CLIENT_ID="your_atlassian_client_id"
TAURI_JIRA_CLIENT_SECRET="your_atlassian_client_secret"

# Linear — https://linear.app/settings/api
TAURI_LINEAR_CLIENT_ID="your_linear_client_id"
TAURI_LINEAR_CLIENT_SECRET="your_linear_client_secret"

# Auto-update signing (tauri-plugin-updater)
# Genera el par de claves con:  pnpm --filter @flowsight/agent exec tauri signer generate -w <ruta>
# - La clave PÚBLICA va en apps/agent/src-tauri/tauri.conf.json (pubkey), commiteada.
# - La PRIVADA es secreta: NUNCA subir al repo. En CI va como GitHub Secret.
# Necesarias en local solo si haces `pnpm build` (createUpdaterArtifacts firma el instalador).
TAURI_SIGNING_PRIVATE_KEY="contenido-de-tu-clave-privada-o-ruta-al-archivo"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="password-de-la-clave-privada"

# Google OAuth - handled by Supabase Dashboard -> Authentication -> Providers -> Google
