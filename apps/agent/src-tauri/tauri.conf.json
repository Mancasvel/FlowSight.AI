{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FlowSight Agent",
  "version": "0.1.0",
  "identifier": "ai.flowsight.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm vite",
    "beforeBuildCommand": "python ../../scripts/fetch-models.py && pnpm vite build"
  },
  "app": {
    "windows": [
      {
        "title": "FlowSight AI - Developer Productivity Agent",
        "width": 370,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 340,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../local_llm/bin/*.exe": "local_llm/bin/",
      "../../../local_llm/bin/*.dll": "local_llm/bin/",
      "../../../local_llm/Qwen3-VL-2B-Instruct-Q3_K_M.gguf": "local_llm/Qwen3-VL-2B-Instruct-Q3_K_M.gguf",
      "../../../local_llm/mmproj-Qwen3VL-2B-Instruct-Q8_0.gguf": "local_llm/mmproj-Qwen3VL-2B-Instruct-Q8_0.gguf"
    }
  }
}