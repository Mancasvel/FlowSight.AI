{
  "name": "flowsight-ai",
  "version": "2.6.2",
  "private": true,
  "description": "FlowSight AI - Privacy-first developer activity monitor with local AI",
  "scripts": {
    "dev": "pnpm --filter @flowsight/agent dev",
    "build": "pnpm --filter @flowsight/agent build",
    "catalog:apps": "cargo run --manifest-path tools/popular-apps-catalog/Cargo.toml"
  },
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1"
  }
}